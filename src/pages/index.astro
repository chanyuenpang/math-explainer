---
import '../styles/global.css';
import { loadProblems, listProblems } from '../lib/problems/registry';

await loadProblems();
const problems = listProblems();
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>MathExplainer - 动态数学题讲解</title>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 min-h-screen">
  <main class="max-w-3xl mx-auto px-4 py-10 md:py-16">
    <div class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">MathExplainer</h1>
      <p class="text-gray-500 text-lg flex items-center justify-center gap-2">
        <span>动态数学题讲解网站</span>
        <span class="text-xs bg-blue-100 text-blue-600 px-2 py-0.5 rounded-full font-mono">v1.0.8</span>
      </p>
    </div>

    <a href="/math-explainer/problems" class="inline-flex items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-xl hover:shadow-lg transition-all mb-10 font-medium">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
      查看全部题目 ({problems.length})
    </a>

    <div class="grid gap-3 md:grid-cols-2">
      {problems.map(problem => (
        <a href={`/math-explainer/problem/${problem.id}`} class="block bg-white/80 backdrop-blur rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-blue-200 hover:bg-white transition-all group">
          <div class="flex items-start justify-between gap-3">
            <h2 class="font-semibold text-gray-800 group-hover:text-blue-600 transition-colors">{problem.title}</h2>
            <span class={`px-2 py-0.5 text-xs rounded-full font-medium whitespace-nowrap ${
              problem.difficulty === 'easy' ? 'bg-green-50 text-green-600 border border-green-100' :
              problem.difficulty === 'medium' ? 'bg-yellow-50 text-yellow-600 border border-yellow-100' :
              'bg-red-50 text-red-600 border border-red-100'
            }`}>{problem.difficulty === 'easy' ? '简单' : problem.difficulty === 'medium' ? '中等' : '困难'}</span>
          </div>
          <div class="mt-3 flex gap-2 flex-wrap">
            {problem.tags.map(tag => (
              <span class="text-xs text-gray-400">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>
</body>
</html>
