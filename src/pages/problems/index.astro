---
import '../../styles/global.css';
import { loadProblems, listProblems, getAllCategories } from '../../lib/problems/registry';

await loadProblems();
const problems = listProblems();
const categories = getAllCategories();
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>题目列表 - MathExplainer</title>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 min-h-screen">
  <header class="bg-white/80 backdrop-blur-sm shadow-sm py-3 sticky top-0 z-50">
    <div class="max-w-4xl mx-4 flex items-center justify-between">
      <a href="/" class="text-blue-500 hover:text-blue-700 hover:underline flex items-center gap-1 font-medium">← 返回首页</a>
      <span class="text-sm font-medium text-gray-600">题目列表</span>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-6 md:py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">全部题目</h1>
      <span class="text-sm text-gray-400">{problems.length} 道题</span>
    </div>

    {categories.length > 0 && (
      <div class="mb-5 flex gap-2 flex-wrap">
        {categories.map(cat => (
          <span class="px-3 py-1 bg-white/60 rounded-full text-sm text-gray-500 border border-gray-100">{cat}</span>
        ))}
      </div>
    )}

    <div class="grid gap-3 md:grid-cols-2">
      {problems.map(problem => (
        <a href={`/math-explainer/problem/${problem.id}`} class="block bg-white/80 backdrop-blur rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-blue-200 hover:bg-white transition-all group">
          <div class="flex items-start justify-between gap-3">
            <h2 class="font-semibold text-lg text-gray-800 group-hover:text-blue-600 transition-colors">{problem.title}</h2>
            <span class={`px-2 py-0.5 text-xs rounded-full font-medium whitespace-nowrap ${
              problem.difficulty === 'easy' ? 'bg-green-50 text-green-600 border border-green-100' :
              problem.difficulty === 'medium' ? 'bg-yellow-50 text-yellow-600 border border-yellow-100' :
              'bg-red-50 text-red-600 border border-red-100'
            }`}>{problem.difficulty === 'easy' ? '简单' : problem.difficulty === 'medium' ? '中等' : '困难'}</span>
          </div>
          {problem.category && (
            <span class="inline-block mt-2 px-2 py-0.5 bg-blue-50 text-blue-500 text-xs rounded-md border border-blue-100">{problem.category}</span>
          )}
          <div class="mt-2 flex gap-2 flex-wrap">
            {problem.tags.map(tag => (
              <span class="text-xs text-gray-400">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    {problems.length === 0 && (
      <p class="text-gray-400 text-center py-8">暂无题目</p>
    )}
  </main>
</body>
</html>
