---
import '../../styles/global.css';
import { loadProblems, listProblems, getAllCategories } from '../../lib/problems/registry';

await loadProblems();
const problems = listProblems();
const categories = getAllCategories();
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>题目列表 - MathExplainer</title>
</head>
<body class="bg-gray-50">
  <header class="bg-white shadow-sm py-4">
    <div class="max-w-4xl mx-auto px-4">
      <a href="/" class="text-blue-500 hover:underline">← 返回首页</a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">题目列表</h1>

    {categories.length > 0 && (
      <div class="mb-6 flex gap-2 flex-wrap">
        {categories.map(cat => (
          <span class="px-3 py-1 bg-gray-100 rounded-full text-sm">{cat}</span>
        ))}
      </div>
    )}

    <div class="grid gap-4 md:grid-cols-2">
      {problems.map(problem => (
        <a href={`/math-explainer/problem/${problem.id}`} class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition">
          <div class="flex items-start justify-between gap-3">
            <h2 class="font-semibold text-lg">{problem.title}</h2>
            <span class={`px-2 py-1 text-xs rounded whitespace-nowrap ${
              problem.difficulty === 'easy' ? 'bg-green-100 text-green-700' :
              problem.difficulty === 'medium' ? 'bg-yellow-100 text-yellow-700' :
              'bg-red-100 text-red-700'
            }`}>{problem.difficulty === 'easy' ? '简单' : problem.difficulty === 'medium' ? '中等' : '困难'}</span>
          </div>
          {problem.category && (
            <span class="inline-block mt-2 px-2 py-0.5 bg-blue-50 text-blue-600 text-xs rounded">{problem.category}</span>
          )}
          <div class="mt-3 flex gap-2 flex-wrap">
            {problem.tags.map(tag => (
              <span class="text-xs text-gray-500">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    {problems.length === 0 && (
      <p class="text-gray-500">暂无题目</p>
    )}
  </main>
</body>
</html>
