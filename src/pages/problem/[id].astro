---
import '../../styles/global.css';
import { loadProblems, getProblem, listProblems } from '../../lib/problems/registry';
import { version as appVersion } from '../../../package.json';

export async function getStaticPaths() {
  await loadProblems();
  return listProblems().map(p => ({ params: { id: p.id } }));
}

await loadProblems();

const { id } = Astro.params;
const problem = getProblem(id!);
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{problem?.title || '题目'}</title>
</head>
<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen">
  <header class="bg-white/90 backdrop-blur-sm shadow-sm py-1.5 px-3 sticky top-0 z-50 flex items-center justify-between">
    <a href="/math-explainer/problems" class="text-blue-500 hover:text-blue-700 text-sm font-medium">← 返回</a>
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-400">MathExplainer</span>
      <span class="text-xs text-gray-300">v{appVersion}</span>
    </div>
  </header>

  <main class="h-[100dvh] flex flex-col overflow-hidden">
    <div class="flex-1 overflow-hidden flex flex-col">
      <div class="px-3 py-2 shrink-0">
        <span class="text-xs text-gray-400 font-mono mb-1 block">{problem?.id}</span>
        <h1 class="text-base md:text-lg font-bold text-gray-800">{problem?.title}</h1>
      </div>

      {problem?.image && (
        <div class="bg-white rounded-lg shadow-sm p-2 mx-3 mb-2 shrink-0 hidden">
          <img src={`/math-explainer${problem.image}`} alt="题目图片" class="max-w-md rounded-lg shadow" />
        </div>
      )}

      {problem?.question?.text && (
        <div class="bg-white rounded-lg shadow-sm p-3 mx-3 mb-2 shrink-0">
          <p class="text-sm text-gray-700 whitespace-pre-wrap">{problem.question.text}</p>
        </div>
      )}

      <div class="flex-1 overflow-hidden flex flex-col min-h-0">
        <div 
          id="combined-root" 
          class="flex-1 flex flex-col min-h-0"
          data-steps={JSON.stringify(problem?.steps)}
          data-geometry={JSON.stringify(problem?.geometry)}
          data-animations={JSON.stringify(problem?.stepAnimations)}
        ></div>
      <script>
        import { createElement, useState } from 'react';
        import { createRoot } from 'react-dom/client';
        import { StepPlayer } from '../../components/StepPlayer';
        import { GeometryCanvas } from '../../components/GeometryCanvas';
        import { ErrorBoundary } from '../../components/ErrorBoundary';

        const root = document.getElementById('combined-root');
        const steps = JSON.parse(root.dataset.steps);
        const geometry = JSON.parse(root.dataset.geometry);
        const animations = JSON.parse(root.dataset.animations);

        function Container() {
          const [currentStep, setCurrentStep] = useState(0);
          const step = steps[currentStep] || {};
          
          return createElement('div', { className: 'flex flex-col h-full' }, [
            createElement(ErrorBoundary, { key: 'canvas-eb' },
              createElement(GeometryCanvas, {
                key: 'canvas',
                points: geometry.points,
                connections: geometry.connections,
                edgeColors: geometry.edgeColors,
                rightAngles: geometry.rightAngles,
                angleArcs: geometry.angleArcs || [],
                equalPairs: geometry.equalPairs,
                triangles: geometry.triangles || [],
                currentStep: currentStep,
                stepAnimations: animations,
                currentStepData: step
              })
            ),
            createElement(ErrorBoundary, { key: 'player-eb' },
              createElement(StepPlayer, {
                key: 'player',
                steps: steps,
                onStepChange: setCurrentStep
              })
            )
          ]);
        }

        createRoot(root).render(createElement(Container));
      </script>
    </div>

    {/* 答案和原题 - 桌面端显示 */}
    <details class="bg-white rounded-lg shadow-sm p-3 mx-3 mb-3 hidden md:block shrink-0">
      <summary class="font-semibold cursor-pointer text-gray-700 hover:text-blue-600 text-sm">查看完整答案</summary>
      <pre class="mt-2 whitespace-pre-wrap text-xs text-gray-600">{problem?.solution?.text}</pre>
    </details>

    {problem?.image && (
      <details class="mt-2 bg-white rounded-lg shadow-sm p-2 mx-3 hidden md:block shrink-0">
        <summary class="font-semibold cursor-pointer text-blue-600 hover:text-blue-800 text-sm">查看原题</summary>
        <div class="mt-2">
          <img src={`/math-explainer${problem.image}`} alt="题目图片" class="max-w-full md:max-w-xs rounded-lg shadow mx-auto" />
        </div>
      </details>
    )}
  </main>
</body>
</html>
