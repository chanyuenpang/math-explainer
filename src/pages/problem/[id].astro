---
import '../../styles/global.css';
import { loadProblems, getProblem, listProblems } from '../../lib/problems/registry';

await loadProblems();
const problems = listProblems();

export function getStaticPaths() {
  return problems.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const problem = getProblem(id!);
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{problem?.title || '题目'}</title>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <header class="bg-white shadow-sm py-4">
    <div class="max-w-4xl mx-auto px-4">
      <a href="/math-explainer/problems" class="text-blue-500 hover:underline">← 返回列表</a>
    </div>
  </header>

  <main class="w-full max-w-4xl mx-auto px-4 py-6 md:py-8">
    <h1 class="text-2xl font-bold mb-4">{problem?.title}</h1>

    <div class="mb-6 hidden">
      <img src={problem?.image} alt="题目图片" class="max-w-md rounded-lg shadow" />
    </div>

    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <h2 class="font-bold text-lg mb-2">题目</h2>
      <pre class="whitespace-pre-wrap font-sans">{problem?.question?.text}</pre>
    </div>

    <div class="mb-8">
      <h2 class="font-bold text-lg mb-4">分步讲解</h2>
      <div 
        id="combined-root" 
        data-steps={JSON.stringify(problem?.steps)}
        data-geometry={JSON.stringify(problem?.geometry)}
        data-animations={JSON.stringify(problem?.stepAnimations)}
      ></div>
      <script>
        import { createElement, useState } from 'react';
        import { createRoot } from 'react-dom/client';
        import { StepPlayer } from '../../components/StepPlayer';
        import { GeometryCanvas } from '../../components/GeometryCanvas';

        const root = document.getElementById('combined-root');
        const steps = JSON.parse(root.dataset.steps);
        const geometry = JSON.parse(root.dataset.geometry);
        const animations = JSON.parse(root.dataset.animations);

        function Container() {
          const [currentStep, setCurrentStep] = useState(0);
          const step = steps[currentStep] || {};
          
          return createElement('div', { className: 'flex flex-col gap-6' }, [
            createElement(GeometryCanvas, {
              key: 'canvas',
              points: geometry.points,
              connections: geometry.connections,
              edgeColors: geometry.edgeColors,
              rightAngles: geometry.rightAngles,
              angleArcs: geometry.angleArcs || [],
              equalPairs: geometry.equalPairs,
              currentStep: currentStep,
              stepAnimations: animations,
              currentStepData: step  // 传递完整的步骤数据
            }),
            createElement(StepPlayer, {
              key: 'player',
              steps: steps,
              onStepChange: setCurrentStep
            })
          ]);
        }

        createRoot(root).render(createElement(Container));
      </script>
    </div>

    <details class="bg-white rounded-lg shadow p-6">
      <summary class="font-bold cursor-pointer">查看完整答案</summary>
      <pre class="mt-4 whitespace-pre-wrap">{problem?.solution?.text}</pre>
    </details>

    {/* 原题图片 - 折叠在底部 */}
    <details class="mt-6 bg-white rounded-lg shadow p-4">
      <summary class="font-bold cursor-pointer text-blue-600 hover:text-blue-800">查看原题</summary>
      <div class="mt-4">
        <img src={problem?.image} alt="题目图片" class="max-w-md rounded-lg shadow mx-auto" />
      </div>
    </details>
  </main>
</body>
</html>
